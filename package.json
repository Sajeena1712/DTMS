{
  "name": "digital-talent-management-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:start\" \"npm run client:dev\" --names \"server,frontend\" --prefix-colors \"blue,green\"",
    "client:dev": "node --require ./scripts/esbuild-spawn-shim.cjs ./node_modules/vite/bin/vite.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "concurrently \"npm run server:start\" \"npm run client:dev\" --names \"server,frontend\" --prefix-colors \"blue,green\"",
    "server:dev": "npm --prefix server run dev",
    "server:start": "npm --prefix server run start",
    "server:seed": "npm --prefix server run seed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "axios": "^1.9.0",
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.5.1",
    "react-router-dom": "^6.30.0",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.1"
  }
}
