{
  "name": "digital-talent-management-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://sajeena1712.github.io/DTMS",
  "scripts": {
    "dev": "scripts\\dev.cmd",
    "client:dev": "node --require ./scripts/esbuild-spawn-shim.cjs ./node_modules/vite/bin/vite.js --configLoader native",
    "build": "vite build --configLoader native",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "node scripts/deploy-pages.mjs",
    "start": "scripts\\dev.cmd",
    "server:dev": "npm --prefix backend run dev",
    "server:start": "npm --prefix backend run start",
    "server:seed": "npm --prefix backend run seed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "axios": "^1.9.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^11.11.17",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.5.1",
    "react-router-dom": "^6.30.0",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.1"
  }
}
