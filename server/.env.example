# ========================================
# BACKEND ENVIRONMENT VARIABLES (.env)
# ========================================

# Application Environment
NODE_ENV=development

# Server Configuration
PORT=3001
CLIENT_URL=http://localhost:5173

# Database Configuration
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/dtms?retryWrites=true&w=majority"

# JWT Configuration  
JWT_SECRET="min-32-characters-long-secret-key-for-production"
JWT_EXPIRES_IN="7d"

# Email Configuration (Optional - for password reset)
# Gmail SMTP
# Get app-specific password from Gmail: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@dtms.app

# Admin Seed Credentials (used on first run)
ADMIN_EMAIL=admin@dtms.com
ADMIN_PASSWORD=Admin@123

# Frontend URLs
FRONTEND_URL=http://localhost:5173
